# Hugging Face Inference API Configuration
# Get your API token from: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_hugging_face_api_token_here

# Model ID from Hugging Face Hub (optional, defaults to deepseek-ai/DeepSeek-V4-Pro)
HF_MODEL_ID=deepseek-ai/DeepSeek-V4-Pro

# FastAPI Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Vector Store Configuration
PERSIST_DIRECTORY=./chroma_db
